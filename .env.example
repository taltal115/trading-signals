# Copy to `.env` (gitignored). Used by Python jobs, GitHub Actions, and the Nest API.

# --- Python bot / scripts (existing)
SLACK_BOT_TOKEN=
# Prefer channel ID C… — Slack Desktop: channel menu → ⋮ → Copy channel ID (or archives URL …/archives/C…).
# channel_not_found → `/invite @YourBot`, add Bot scopes channels:read + channels:join → reinstall app (or paste C… only).
# GitHub Actions: SLACK_CHANNEL secret (optional; overrides config yaml).
SLACK_CHANNEL=
SLACK_BOT_NAME=
EODHD_API_KEY=
FINNHUB_API_KEY=
# Optional: Stooq daily CSV ?apikey= (overrides config.yaml `data.stooq_api_key`). Yahoo is used first by default.
STOOQ_API_KEY=
# OpenAI: required for real LLM in `ai-stock-eval` / `ai-entry-batch` / `ai-holding-advisor`.
# Set same value as GitHub repo secret OPENAI_API_KEY. Docs: docs/ai-signal-pipeline/RUNBOOK.md
# Without it, jobs log source=stub (WAIT placeholder). Nest does not call OpenAI.
# Models (config.yaml): entry gpt-5.4, holding gpt-5.4-mini, optional gpt-5.4-pro when score >= pro_min_technical_score.
# Local: scripts/run_ai_stock_eval.sh --ticker AAPL --signal-doc-id demo --candidate-score 70 --dry-run --stdout-json
# Batch: PYTHONPATH=./src:. python -m scripts.ai_stock_eval.main --batch
# Holding: PYTHONPATH=./src:. python -m scripts.ai_holding_advisor.main --config config.yaml
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4
# Broader headlines for AI prompts (optional; Finnhub still used first).
NEWSAPI_API_KEY=
# USE_NEWSAPI=true
# GDELT needs no key (free). Disable with USE_GDELT=false if noisy/rate-limited.
# USE_GDELT=true
# Optional macro snippets (CPI / rates / unemployment) in {{events}} when set.
FRED_API_KEY=
# USE_FRED=true
# Optional: daily candles for dashboard charts (Nest `/api/market/candles`; Finnhub free tier often blocks stock/candle)
TWELVE_DATA_API_KEY=
# Nest also reads `ALPHAVANTAGE_API_KEY` (no underscore) for Python compatibility
ALPHA_VANTAGE_API_KEY=
FLEX_API_KEY=
# IBKR Client Portal Gateway (https://localhost:5000/v1/api) — optional; overrides config.yaml base_url
# IBKR_CP_GATEWAY_URL=https://localhost:5000/v1/api
# IBKR_CP_ACCOUNT_ID=
ALPHAVANTAGE_API_KEY=
# Fine-grained or classic PAT with **Actions: Read and write** (workflow dispatch). Used by Nest only — not the browser.
GITHUB_PERSONAL_TOKEN=
# Position monitor script: auto-close Firestore rows on TARGET_HIT/STOP_HIT (default true). Set false to only log/Slack.
# MONITOR_AUTO_CLOSE=true
# Optional (defaults: taltal115 / trading-signals)
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=

# Firebase Admin: path to service account JSON.
# If you run `npm run start:dev` from `backend/`, use ../filename.json (repo root) or an absolute path.
GOOGLE_APPLICATION_CREDENTIALS=
# Or inline JSON (Nest also reads this):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Nest API (backend/) — see docs/backend-api.md
# `/api/signals` always reads Firestore collection `signals` (not configurable).
# Set false to turn off /api/market/* (no Finnhub / Twelve Data / Alpha Vantage calls or logs)
MARKET_DATA_ENABLED=true
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me
FRONTEND_URL=http://localhost:4200
# Prod: Nest 307s the other default Firebase host to FRONTEND_URL (web.app <-> firebaseapp.com). ALT_HOSTING_HOSTNAME=- disables.

# Local dev only — never in production
AUTH_BYPASS_LOCAL=true
DEV_OWNER_UID=
DEV_USER_EMAIL=dev@localhost
# Optional label for sidebar when using legacy single-user bypass (no DEV_LOCAL_USERS).
# DEV_USER_DISPLAY_NAME=Local Trader
#
# Multi-persona local testing: JSON array of { "uid", "email", optional "displayName" } — must align with ALLOWED_* if you touch real Firestore.
# Cookie `dev_persona` selects uid (set via POST /api/auth/dev/persona).
# DEV_LOCAL_USERS=[{"uid":"firebaseUid1","email":"a@localhost","displayName":"Alice"},{"uid":"firebaseUid2","email":"b@localhost","displayName":"Bob"}]

# Production Google OAuth (optional when using AUTH_BYPASS_LOCAL)
# No quotes around values (or they are stripped). Must be OAuth "Web application" client from the same GCP project as Firebase.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4200/api/auth/google/callback

# Allowlist — mirror `frontend/src/environments/environment.prod.ts` (comma-separated, no spaces).
# Example: ALLOWED_SIGN_IN_EMAILS=you@gmail.com,teammate@gmail.com
ALLOWED_SIGN_IN_EMAILS=
# Optional: comma-separated Firebase Auth UIDs (`Authentication` → Users in Firebase console).
ALLOWED_AUTH_UIDS=
