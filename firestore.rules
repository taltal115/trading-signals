rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /universe/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Canonical signal runs (deterministic doc ids; written by server Admin SDK only).
    match /signals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Archived legacy auto-id runs (pre-rename ``signals`` → ``signals_old``).
    match /signals_old/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Canonical positions (deterministic ids after migrate; owner-scoped reads/writes via rules).
    match /my_positions/{posId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.owner_uid;
      allow create: if request.auth != null
        && request.resource.data.owner_uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.owner_uid == request.auth.uid
        && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
    }

    // Archived legacy rows (optional read-only browse; rename from pre-cutover ``my_positions`` → ``my_positions_old``).
    match /my_positions_old/{posId} {
      allow read: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
      allow write: if false;
    }

    // collectionGroup queries require a wildcard-path rule
    match /{path=**}/checks/{checkId} {
      allow read: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
      allow write: if false;
    }
  }
}
