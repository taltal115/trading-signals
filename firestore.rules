rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /universe/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /signals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Same shape as ``signals``; deterministic doc ids (date_time). Written by server (Admin SDK) only.
    match /signals_new/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // my_positions: any signed-in user may only access rows they own (owner_uid == auth.uid).
    // Who may sign in (Google allowlist) is enforced in the web app + Firebase Auth settings, not duplicated here —
    // the JWT "email" claim is unreliable in rules right after redirect.
    match /my_positions/{posId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.owner_uid;
      allow create: if request.auth != null
        && request.resource.data.owner_uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.owner_uid == request.auth.uid
        && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
    }

    // collectionGroup queries require a wildcard-path rule
    match /{path=**}/checks/{checkId} {
      allow read: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
      allow write: if false;
    }
  }
}
